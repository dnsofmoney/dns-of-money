# ── xapp-frontend env template ────────────────────────────────────────────
# Copy to .env.local for local dev. Only VITE_* vars reach the browser.
#
# SECURITY: NEVER add VITE_XUMM_API_SECRET here. The Xaman API secret lives
# only on the FAS stack backend (set XUMM_API_SECRET in financial-autonomy-stack/.env).
# If you find yourself typing it below, stop.

# Base URL for the FAS stack backend that handles OTT exchange.
# Local dev:   http://localhost:8000
# Via tunnel:  https://<your-tunnel>.trycloudflare.com   or   https://<id>.ngrok.app
# Production:  https://api.dnsofmoney.com
VITE_API_BASE_URL=http://localhost:8000
